{
  "name": "@dnvsol/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --tsconfig tsconfig.json src/index.ts",
    "start": "node dist/index.js",
    "db:migrate": "typeorm migration:run -d dist/config/data-source.js",
    "db:seed": "node dist/seeds/seed.js",
    "db:migration:generate": "typeorm migration:generate -d src/config/data-source.ts",
    "db:migration:create": "typeorm migration:create",
    "db:migration:revert": "typeorm migration:revert -d dist/config/data-source.js"
  },
  "dependencies": {
    "@dnvsol/shared": "*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.18.2",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "socket.io": "^4.7.0",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
