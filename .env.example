# ============================================================
# DNVSol Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ---------- Database (MySQL) ----------
# Local: mysql://dnvsol:dnvsol@localhost:3306/dnvsol_dev
# Hostinger: mysql://u556802886_user:password@localhost:3306/u556802886_dnvsol
DATABASE_URL=mysql://dnvsol:dnvsol@localhost:3306/dnvsol_dev

# ---------- Auth ----------
JWT_SECRET=change-me-must-be-at-least-32-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---------- Application ----------
API_PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ---------- CORS ----------
# Dev: http://localhost:5173
# Prod: https://dnvsol.org
CORS_ORIGINS=http://localhost:5173

# ---------- Rate Limiting ----------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
